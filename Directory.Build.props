<Project>
  <PropertyGroup>
    <OniGameDir Condition="'$(OniGameDir)' == ''">D:\SteamLibrary\steamapps\common\OxygenNotIncluded</OniGameDir>
    <OniManagedDir>$(OniGameDir)\OxygenNotIncluded_Data\Managed</OniManagedDir>
    <LangVersion>7.3</LangVersion>
    <Deterministic>true</Deterministic>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>
</Project>
